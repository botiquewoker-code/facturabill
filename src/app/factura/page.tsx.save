'use client';

import React, { useState } from 'react';
import { Upload, Plus, Trash2, Copy, Download, Send } from 'lucide-react';
import { Toaster } from 'react-hot-toast';
import dynamic from 'next/dynamic';
import InvoicePDF from '@/components/InvoicePDF';

const PDFViewer = dynamic(() => import('@react-pdf/renderer').then(mod => mod.PDFViewer), { ssr: false });

type Item = { desc: string; cant: number; precio: number };
type Empresa = { nombre: string; nif: string; direccion: string; ciudad: string; cp: string; telefono: string; email: string };
type Cliente = { nombre: string; nif: string; direccion: string; ciudad: string; cp: string; telefono: string; email: string };

const plantillas = [
  { id: 'elegante', nombre: 'Elegante', color: 'from-amber-900 to-black' },
  { id: 'minimal', nombre: 'Minimalista', color: 'from-white to-gray-100' },
  { id: 'clasica', nombre: 'Clásica', color: 'from-blue-50 to-blue-100' },
  { id: 'moderno', nombre: 'Moderno', color: 'from-indigo-500 to-purple-600' },
];

export default function CrearDocumento() {
  const [esPresupuesto, setEsPresupuesto] = useState(false);
  const [numero, setNumero] = useState(`FAC-${new Date().getFullYear()}-001`);
  const [fecha] = useState(new Date().toISOString().split('T')[0]);

  const formatLabel = (key: string) => {
    if (key === 'nif') return 'NIF/CIF';
    if (key === 'cp') return 'C.P.';
    return key.charAt(0).toUpperCase() + key.slice(1);
  };
  const [cliente, setCliente] = useState<Cliente>({ nombre: '', nif: '', direccion: '', ciudad: '', cp: '', telefono: '', email: '' });
  const [items, setItems] = useState<Item[]>([{ desc: '', cant: 1, precio: 0 }]);
  const [logo, setLogo] = useState<string>('');
  const [plantilla, setPlantilla] = useState('moderno');
  const [notas, setNotas] = useState('');
  const nombre = datos?.nombre || "";

  const subtotal = items.reduce((s, i) => s + i.cant * i.precio, 0);
  const iva = subtotal * 0.21;
  const total = subtotal + iva;
  const datos = { esPresupuesto, numero, fecha, cliente, items, logo, plantilla, subtotal, iva, total, notas };

  const handleLogo = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => setLogo(reader.result as string);
    reader.readAsDataURL(file);
  };

  const descargar = async () => {
    const pdf = await import('@react-pdf/renderer');
    const blob = await pdf.pdf(<InvoicePDF datos={datos} />).toBlob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${esPresupuesto ? 'Presupuesto' : 'Factura'}_${numero}.pdf`;
    a.click();
    URL.revokeObjectURL(url);
  };

  const enviar = async () => {
    if (!cliente.email) return alert('Falta el email del cliente');
    const pdf = await import('@react-pdf/renderer');
    const blob = await pdf.pdf(<InvoicePDF datos={datos} />).toBlob();
    const formData = new FormData();
    formData.append('file', blob, `${esPresupuesto ? 'Presupuesto' : 'Factura'}_${numero}.pdf`);
    formData.append('to', cliente.email);
    formData.append('subject', `${esPresupuesto ? 'Presupuesto' : 'Factura'} ${numero} - ${Nombre}`);
    formData.append('text', `Hola,\n\nAdjunto ${esPresupuesto ? 'el presupuesto' : 'la factura'} ${numero}.\n\nGracias.\n${nombre || 'Tu proveedor'}`);
    const res = await fetch('/api/enviar-email', { method: 'POST', body: formData });
    res.ok ? alert('¡Enviado correctamente!') : alert('Error al enviar');
  };

  return (
    <>
      <Toaster position="top-right" />
      <div className="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100">
        <div className="flex flex-col lg:flex-row">

          {/* FORMULARIO */}
          <div className="flex-1 p-4 lg:p-8 overflow-y-auto pb-32 lg:pb-8">
            <div className="max-w-4xl mx-auto space-y-6">

              {/* PLANTILLAS MÓVIL */}
              <div className="lg:hidden bg-white rounded-2xl shadow p-4">
                <div className="grid grid-cols-4 gap-3">
                  {plantillas.map(p => (
                    <button key={p.id} onClick={() => setPlantilla(p.id)}
                      className={`rounded-xl overflow-hidden ${plantilla === p.id ? 'ring-2 ring-indigo-600' : ''}`}>
                      <div className={`h-16 bg-gradient-to-br ${p.color} flex items-center justify-center`}>
                       <span className={`text-xs font-bold px-2 py-1 rounded 
                       ${p.id === 'minimal' || p.id === 'clasica' ? 'text-gray-800' : 'text-white'} 
                       ${p.id === 'minimal' || p.id === 'clasica' ? 'bg-white/80' : 'bg-black/30'}`}>
                       {p.nombre}
                       </span>
                      </div>
                    </button>
                  ))}
                </div>
              </div>

              {/* CABECERA */}
              <div className="bg-white rounded-2xl shadow p-6">
                <div className="flex justify-between items-center mb-4">
                  <h1 className="text-3xl font-bold text-gray-900">{esPresupuesto ? 'PRESUPUESTO' : 'FACTURA'}</h1>
                  <button onClick={() => setEsPresupuesto(!esPresupuesto)}
                    className="text-indigo-600 font-medium flex items-center gap-2">
                    <Copy size={18} /> {esPresupuesto ? 'A Factura' : 'A Presupuesto'}
                  </button>
                </div>
                <div className="grid grid-cols-2 gap-4">
                  <input className="bg-gray-50 rounded-xl px-4 py-3" value={numero} onChange={e => setNumero(e.target.value)} placeholder="Número" />
                  <input type="date" className="bg-gray-50 rounded-xl px-4 py-3" value={fecha} readOnly />
                </div>
              </div>

              {/* TUS DATOS */}
              <div className="bg-blue-50 rounded-2xl p-6">
                <h2 className="text-lg font-bold mb-4 text-blue-900">Datos del emisor</h2>
                <div className="grid grid-cols-2 gap-3 text-sm">
                  {Object.entries(empresa).map(([k, v]) => (
                    <input
                      key={k}
                      className="bg-white border border-blue-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-blue-400/70"
                      placeholder={formatLabel(k)}
                      value={v}
                      onChange={e => setEmpresa(p => ({ ...p, [k]: e.target.value }))}
                    />
                  ))}
                </div>
              </div>

              {/* CLIENTE */}
              <div className="bg-blue-50 rounded-2xl shadow p-6">
                <h2 className="text-lg font-bold mb-4 text-blue-900">Datos del cliente</h2>
                <div className="grid grid-cols-2 gap-3 text-sm">
                  {Object.entries(cliente).map(([k, v]) => (
                    <input
                      key={k}
                      className="bg-white border border-blue-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-blue-400/70"
                      placeholder={formatLabel(k)}
                      value={v}
                      onChange={e => setCliente(p => ({ ...p, [k]: e.target.value }))}
                    />
                  ))}
                </div>
              </div>

              {/* CONCEPTOS */}
              <div className="bg-white rounded-2xl shadow p-6">
                <div className="flex justify-between items-center mb-4">
                  <h2 className="text-lg font-bold">Conceptos</h2>
                  <button onClick={() => setItems([...items, { desc: '', cant: 0, precio: 0 }])}
                    className="text-indigo-600 flex items-center gap-1 text-sm">
                    <Plus size={18} /> Añadir
                  </button>
                </div>

                {items.map((item, i) => (
                  <div key={i} className="grid grid-cols-12 gap-3 mb-3 items-center text-sm">
                    <input
                      className="col-span-7 bg-gray-50 rounded-xl px-3 py-2"
                      placeholder="Descripción"
                      value={item.desc}
                      onChange={e => setItems(prev => {
                        const nuevo = [...prev];
                        nuevo[i].desc = e.target.value;
                        return nuevo;
                      })}
                    />
                    {/* CANTIDAD – ahora sí queda vacío */}
                    <input
                      type="number"
                      min="1"
                      placeholder="1"
                      className="col-span-2 bg-gray-50 rounded-xl px-3 py-2 text-center"
                      value={item.cant === 0 || item.cant === 1 ? '' : item.cant}
                      onChange={e => {
                        const val = e.target.value;
                        setItems(prev => {
                          const nuevo = [...prev];
                          nuevo[i].cant = val === '' ? 1 : Number(val) || 1;
                          return nuevo;
                        });
                      }}
                    />
                    {/* PRECIO – ahora sí queda vacío */}
                    <input
                      type="number"
                      step="0.01"
                      placeholder="0.00"
                      className="col-span-2 bg-gray-50 rounded-xl px-3 py-2 text-center"
                      value={item.precio === 0 ? '' : item.precio}
                      onChange={e => {
                        const val = e.target.value;
                        setItems(prev => {
                          const nuevo = [...prev];
                          nuevo[i].precio = val === '' ? 0 : Number(val) || 0;
                          return nuevo;
                        });
                      }}
                    />
                    <div className="col-span-1 text-right font-medium">
                      {(item.cant * item.precio).toFixed(2)}€
                    </div>
                    <button
                      onClick={() => setItems(items.filter((_, idx) => idx !== i))}
                      className="text-red-600 hover:text-red-800"
                    >
                      <Trash2 size={20} />
                    </button>
                  </div>
                ))}
              </div>

              {/* LOGO + TOTAL + NOTAS */}
              <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                {/* Logo */}
                <div className="bg-white rounded-2xl shadow p-6 text-center">
                  <label className="block border-2 border-dashed border-blue-5 rounded-2xl p-8 cursor-pointer hover:border-indigo-500 transition">
                    <Upload size={32} className="mx-auto mb-2 text-gray-400" />
                    <span className="text-sm">{logo ? 'Logo listo' : 'Subir logo'}</span>
                    <input type="file" accept="image/*" onChange={handleLogo} className="hidden" />
                  </label>
                  {logo && <img src={logo} alt="Logo" className="mt-4 max-h-32 mx-auto rounded-lg shadow" />}
                </div>

                {/* Total */}
                <div className="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl p-6 text-white text-right">
                  <div className="space-y-2">
                    <div>
                      <span className="text-sm opacity-90">Base</span>
                      <span className="text-2xl font-bold ml-3">{subtotal.toFixed(2)}€</span>
                    </div>
                    <div>
                      <span className="text-sm opacity-90">IVA 21%</span>
                      <span className="text-2xl font-bold ml-3">{iva.toFixed(2)}€</span>
                    </div>
                    <div className="text-3xl font-black pt-3 border-t border-white/30">
                      TOTAL {total.toFixed(2)}€
                    </div>
                  </div>
                </div>

                {/* Notas */}
                <div className="bg-white rounded-2xl shadow p-6">
                  <textarea
                    className="w-full h-32 bg-gray-50 rounded-xl px-4 py-3 text-sm resize-none"
                    placeholder="Notas / Condiciones..."
                    value={notas}
                    onChange={e => setNotas(e.target.value)}
                  />
                </div>
              </div>
            </div>
          </div>
               
          {/* PIE DE PÁGINA WEB – SIEMPRE VISIBLE */}
          <div className="mt-12 pb-32 lg:pb-12">
            <div className="max-w-4xl mx-auto px-6">
              <div className="border-t border-gray-300 pt-8 text-center text-xs text-gray-500 space-y-2">
                <p className="font-medium text-gray-700">
                  {empresa.nombre} · NIF {empresa.nif} · {empresa.ciudad}
                </p>
                <p>
                  {empresa.direccion} · {empresa.cp} {empresa.ciudad} · Tel: {empresa.telefono}
                </p>
                <p className="text-gray-600">
                  Condiciones: Pago en 30 días · IVA 21% incluido · Protección de datos según RGPD
                </p>
                <p>
                  <a href="mailto:{empresa.email}" className="underline">{empresa.email}</a> · 
                  <a href="https://tuempresa.com/privacidad" className="underline"> Privacidad</a> · 
                  <a href="https://tuempresa.com/ayuda" className="underline"> Ayuda</a>
                </p>
                <p className="text-gray-400 text-xs mt-4">
                  © {new Date().getFullYear()} {empresa.nombre} · Todos los derechos reservados
                </p>
              </div>
            </div>
          </div>

          {/* BOTONES FIJOS MÓVIL */}
          <div className="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t p-4 shadow-lg">
            <div className="max-w-4xl mx-auto flex justify-center gap-6">
              <button
                onClick={descargar}
                className="bg-indigo-600 hover:bg-indigo-700 text-white px-10 py-4 rounded-xl font-bold flex items-center gap-3 shadow"
              >
                <Download size={24} /> Descargar
              </button>
              <button
                onClick={enviar}
                className="bg-green-600 hover:bg-green-700 text-white px-10 py-4 rounded-xl font-bold flex items-center gap-3 shadow"
              >
                <Send size={24} /> Enviar
              </button>
            </div>
          </div>
        </div>
      </div>
    </>
  );
}

